# Secrets and credentials
.leakscan.local
.env
.env.*
!.env.example
secrets.*
credentials.*
*.key
*.pem
*.pfx
*.p12

# Data (user-supplied) and staging (transient) — keep folders via .gitkeep
workflows/*/input/*
workflows/*/output/*
!workflows/*/input/.gitkeep
!workflows/*/output/.gitkeep
**/_ocr_cache/
**/.ocr_cache/
**/.ocr_cache
**/.last_run
**/run-log.csv
_core/token-tracker/usage-log.jsonl
state.json
*.log

# Editor / OS / build
.vscode/
.idea/
.claude/settings.local.json
.DS_Store
Thumbs.db
__pycache__/
*.pyc
.venv/
.venv-*/
venv/
node_modules/
~$*

# Windows Sandbox configs (contain absolute, machine-specific host paths)
**/.sandbox/

# Generated, machine-specific harness MCP configs (source of truth is _core/integrations/servers.json)
.mcp.json
